{
  "name": "octavian",
  "version": "3.0.0",
  "description": "Type-safe music theory utilities for notes, intervals, chords, and scales.",
  "keywords": [
    "music-theory",
    "notes",
    "chords",
    "scales",
    "intervals",
    "midi",
    "typescript",
    "music",
    "audio",
    "browser",
    "web-audio",
    "web-audio-api"
  ],
  "homepage": "https://github.com/stevekinney/octavian#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/octavian/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/octavian.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser/index.js",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    },
    "./sequences": {
      "types": "./dist/sequences/index.d.ts",
      "browser": "./dist/browser/sequences/index.js",
      "import": "./dist/browser/sequences/index.js",
      "default": "./dist/browser/sequences/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check": "bun run format:check && bun run lint && bun run typecheck",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,md}\"",
    "lint": "oxlint --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
    "package:check": "publint && env npm_config_ignore_scripts=true attw --pack --profile esm-only",
    "prepack": "bun run build",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run validate",
    "test": "bun test --parallel",
    "test:ci": "bun test --coverage --parallel",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit --project tsconfig.test.json",
    "smoke:tarball": "bun scripts/smoke-tarball.mjs",
    "validate": "bun run scripts/validate.ts",
    "validate:artifacts": "bun run scripts/validate-artifacts.ts",
    "verify:release-version": "bun run scripts/verify-release-version.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.3",
    "@types/bun": "^1.3.13",
    "chalk": "^5.6.2",
    "fast-check": "^4.7.0",
    "lefthook": "^2.1.6",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.17.4",
    "prettier": "^3.8.3",
    "publint": "^0.3.12",
    "sort-package-json": "^3.6.1",
    "tsdown": "^0.21.10",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22"
  },
  "packageManager": "bun@1.3.2"
}
